---
import Base from '../layouts/Base.astro';
import Converter from '../components/Converter.astro';
import Icon from '../components/Icon.astro';
import FeatureProof from '../components/sections/FeatureProof.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import DeveloperBand from '../components/sections/DeveloperBand.astro';
import Faq from '../components/sections/Faq.astro';
import { SITE } from '../consts';
import { softwareAppSchema, faqSchema } from '../lib/schema';

const site = Astro.site ?? new URL('https://docx-to-markdown.dev');
const jsonLd = [softwareAppSchema(site), faqSchema()];
---

<Base
  title="Convert DOCX to Markdown - free & private"
  description={SITE.description}
  path="/"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Open source · Runs in your browser</p>
      <h1 class="hero-title">
        Word documents, turned into
        <span class="hero-accent">Markdown that keeps its structure.</span>
      </h1>
      <p class="hero-sub">
        Drop a <code>.docx</code> and get clean GitHub-Flavored or CommonMark
        Markdown - tables, images, lists, footnotes and metadata intact. Free,
        private, and instant.
      </p>

      <Converter />

      <ul class="hero-trust">
        <li><Icon name="lock" size={16} /> Files never uploaded</li>
        <li><Icon name="bolt" size={16} /> Converts in milliseconds</li>
        <li><Icon name="github" size={16} /> MIT open source</li>
      </ul>
    </div>
  </section>

  <FeatureProof />
  <HowItWorks />
  <DeveloperBand />
  <Faq />
</Base>

<style>
  .hero {
    padding-top: clamp(2rem, 5vw, 3.5rem);
    padding-bottom: var(--space-7);
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
  }
  .hero-title {
    font-size: var(--text-3xl);
    max-width: 20ch;
    margin-top: 1rem;
  }
  .hero-accent {
    color: var(--violet);
  }
  .hero-sub {
    margin-top: 1.1rem;
    margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
    max-width: 60ch;
    font-size: var(--text-md);
    color: var(--muted);
  }
  .hero-sub code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--rust);
    background: var(--rust-wash);
    padding: 0.05em 0.35em;
    border-radius: 5px;
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.75rem;
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
  }
  .hero-trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .hero-trust svg {
    color: var(--violet);
  }
</style>
